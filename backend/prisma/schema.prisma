generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
}

model Client {
  id      Int    @id @default(autoincrement())
  name    String
  document String
  email   String?
  phone   String?
}
